generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// USERS
//

model User {
  id        String  @id @default(cuid())
  name      String
  email     String? @unique
  password  String?
  avatarUrl String?

  teachSkill String?
  learnSkill String?

  walletAddress String? @unique
  walletNonce   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  swapsInitiated Swap[]         @relation("Initiator")
  swapsReceived  Swap[]         @relation("Receiver")
  proofs         Proof[]
  messages       Message[]
  notifications  Notification[]
  deliveries     Delivery[]
}

//
// SWAPS
//

model Swap {
  id String @id @default(cuid())

  initiatorId String
  receiverId  String

  status SwapStatus @default(PENDING)

  adaTxHash String?

  initiatorDone      Boolean @default(false)
  receiverDone       Boolean @default(false)
  initiatorDelivered Boolean @default(false)
  receiverDelivered  Boolean @default(false)

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  initiator User @relation("Initiator", fields: [initiatorId], references: [id])
  receiver  User @relation("Receiver", fields: [receiverId], references: [id])

  messages   Message[]
  deliveries Delivery[]
  proof      Proof?
}

enum SwapStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
}

//
// PROOF
//

model Proof {
  id String @id @default(cuid())

  swapId String @unique
  userId String

  teachSkill String
  learnSkill String
  adaTxHash  String

  metadataHash String?
  summary      String?

  createdAt DateTime @default(now())

  swap Swap @relation(fields: [swapId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

//
// DELIVERY
//

model Delivery {
  id String @id @default(cuid())

  swapId String
  userId String

  resourceLink String
  notes        String?

  submittedAt DateTime @default(now())

  swap Swap @relation(fields: [swapId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@unique([swapId, userId])
}

//
// SOCIAL LAYER
//

enum MessageType {
  TEXT
  SWAP_ACCEPTED
  SWAP_DECLINED
  SESSION_SCHEDULED
  DELIVERABLE_SUBMITTED
  PROOF_CREATED
  VERIFICATION_COMPLETED
}

model Message {
  id String @id @default(cuid())

  swapId   String
  senderId String

  content  String
  type     MessageType @default(TEXT)
  metadata String?

  createdAt DateTime @default(now())

  swap   Swap @relation(fields: [swapId], references: [id])
  sender User @relation(fields: [senderId], references: [id])
}

model Notification {
  id String @id @default(cuid())

  userId String

  type    NotificationType
  message String
  read    Boolean          @default(false)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum NotificationType {
  SWAP_REQUEST
  SWAP_ACCEPTED
  SWAP_DECLINED
  SWAP_COMPLETED
  PERFECT_MATCH
}
