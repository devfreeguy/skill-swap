generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

//
// USERS
//

model User {
  id        String  @id @default(cuid())
  name      String
  email     String? @unique
  password  String?
  avatarUrl String?
  bio       String?

  teachSkill String?
  learnSkill String?

  twitterId     String? @unique
  walletAddress String? @unique

  // Public key for end-to-end encrypted messaging (derived from a wallet
  // signature on the client). Private key never leaves the user's device.
  publicKey String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  swapsInitiated Swap[]         @relation("Initiator")
  swapsReceived  Swap[]         @relation("Receiver")
  proofs         Proof[]
  messages       Message[]
  notifications  Notification[]
  deliveries     Delivery[]
}

//
// SWAPS
//

model Swap {
  id String @id @default(cuid())

  initiatorId String
  receiverId  String

  status SwapStatus @default(PENDING)

  // The specific skills exchanged in this swap, chosen at request time:
  // initiatorSkill = what the initiator teaches the receiver
  // receiverSkill  = what the receiver teaches the initiator
  initiatorSkill String?
  receiverSkill  String?

  adaTxHash String?

  // Platform sustainability fee. The initiator pays a small fee (default 2 ADA)
  // when requesting a swap; it is refunded ONLY if the receiver declines.
  //   feeTxHash     — the initiator's on-chain fee payment tx
  //   feeLovelace   — amount paid, in lovelace (audit trail; 1 ADA = 1_000_000)
  //   refundAddress — the initiator's payment address to refund to on decline
  //   refundTxHash  — the platform's refund tx (set once refunded)
  //   paymentStatus — CONFIRMED (verified from the signed tx at request time)
  //                   → KEPT (accepted/cancelled) | REFUNDED (declined)
  //                   REFUND_PENDING (refund deferred/retrying) | FAILED
  feeTxHash     String?
  feeLovelace   Int?
  refundAddress String?
  refundTxHash  String?
  paymentStatus String?

  initiatorDone      Boolean @default(false)
  receiverDone       Boolean @default(false)
  initiatorDelivered Boolean @default(false)
  receiverDelivered  Boolean @default(false)

  // Last time each participant opened this conversation — drives unread counts.
  initiatorLastReadAt DateTime?
  receiverLastReadAt  DateTime?

  completedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  initiator User @relation("Initiator", fields: [initiatorId], references: [id])
  receiver  User @relation("Receiver", fields: [receiverId], references: [id])

  messages      Message[]
  deliveries    Delivery[]
  proof         Proof?
  notifications Notification[]
}

enum SwapStatus {
  PENDING
  ACTIVE
  COMPLETED
  DECLINED
  CANCELLED
}

//
// PROOF
//

model Proof {
  id String @id @default(cuid())

  swapId String @unique
  userId String

  teachSkill String
  learnSkill String
  adaTxHash  String?

  metadataHash String?
  summary      String?

  // On-chain anchoring of the proof (user wallet signs a metadata tx).
  // chainStatus: PENDING | ANCHORING | ANCHORED | FAILED
  chainTxHash String?
  chainStatus String?
  network     String?
  anchoredAt  DateTime?

  createdAt DateTime @default(now())

  swap Swap @relation(fields: [swapId], references: [id])
  user User @relation(fields: [userId], references: [id])
}

//
// DELIVERY
//

enum DeliverableType {
  LINK
  FILE
  IMAGE
  DOCUMENT
  TEXT
}

model Delivery {
  id String @id @default(cuid())

  swapId String
  userId String

  // A swap can hold many deliverables per participant, of varying types —
  // these are the concrete outcomes of the exchange, not a single link.
  type  DeliverableType @default(LINK)
  title String?

  resourceLink String? // url for LINK/FILE/IMAGE/DOCUMENT
  notes        String? // free text for TEXT, or a description for others

  fileName String?
  fileSize Int?
  mimeType String?

  submittedAt DateTime @default(now())

  swap Swap @relation(fields: [swapId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([swapId])
  @@index([swapId, userId])
}

//
// SOCIAL LAYER
//

enum MessageType {
  TEXT
  LINK
  IMAGE
  DOCUMENT
  SWAP_ACCEPTED
  SWAP_DECLINED
  SESSION_SCHEDULED
  DELIVERABLE_SUBMITTED
  PROOF_CREATED
  VERIFICATION_COMPLETED
}

model Message {
  id String @id @default(cuid())

  swapId   String
  senderId String

  content  String
  type     MessageType @default(TEXT)
  metadata String?

  // End-to-end encrypted payload. For user chat messages `content` is left
  // empty and the real text lives here as ciphertext (server can't read it).
  // System events (e.g. "Swap accepted") still use plaintext `content`.
  ciphertext      String?
  nonce           String?
  senderPublicKey String?

  fileUrl  String?
  fileName String?
  fileSize Int?

  createdAt DateTime @default(now())

  swap   Swap @relation(fields: [swapId], references: [id])
  sender User @relation(fields: [senderId], references: [id])
}

model Notification {
  id String @id @default(cuid())

  userId String
  swapId String?

  type    NotificationType
  message String
  read    Boolean          @default(false)

  createdAt DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  swap Swap? @relation(fields: [swapId], references: [id])
}

enum NotificationType {
  SWAP_REQUEST
  SWAP_ACCEPTED
  SWAP_DECLINED
  SWAP_COMPLETED
  PERFECT_MATCH
  PROOF_CREATED
}

//
// WALLET AUTH
//

// Single-use challenge nonces for CIP-8 wallet login/registration. Persisted
// (not in-memory) so the challenge survives restarts and is shared across all
// serverless instances. Consumed by an atomic delete; expired rows are GC'd
// opportunistically on issue.
model WalletNonce {
  nonce     String   @id
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([expiresAt])
}
