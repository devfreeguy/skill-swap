# ── Database ─────────────────────────────────────────────────────────────────
# NeonDB connection strings — one per network plus a fallback for unauthenticated routes
DATABASE_URL=postgresql://user:pass@host/db
DATABASE_URL_PREPROD=postgresql://user:pass@host/db_preprod
DATABASE_URL_MAINNET=postgresql://user:pass@host/db_mainnet

# ── Auth ──────────────────────────────────────────────────────────────────────
# JWT signing secret + app base URL for the Twitter OAuth redirect callback
JWT_SECRET=a_long_random_secret
NEXTAUTH_URL=http://localhost:3000

# ── Twitter / X OAuth2 ────────────────────────────────────────────────────────
# Register at developer.x.com — callback: $NEXTAUTH_URL/api/auth/twitter/callback
TWITTER_CLIENT_ID=get_from_x_developer
TWITTER_CLIENT_SECRET=get_from_x_developer

# ── Cardano Network ───────────────────────────────────────────────────────────
# Active Cardano network for the wallet SDK — mainnet | preprod | preview
NEXT_PUBLIC_CARDANO_NETWORK=preprod

# ── Cardano Providers ─────────────────────────────────────────────────────────
# On-chain tx submission/confirmation — per-network keys required; BLOCKFROST_API_KEY is the fallback
BLOCKFROST_API_KEY=
BLOCKFROST_API_KEY_PREPROD=preprodXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
BLOCKFROST_API_KEY_MAINNET=mainnetXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
MAESTRO_API_KEY=

# ── Swap Fees ─────────────────────────────────────────────────────────────────
# Treasury wallet address, fee amount (lovelace), and seed phrase per network — blank address disables fees
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS_PREPROD=addr_test1...
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS_MAINNET=addr1...
NEXT_PUBLIC_SWAP_FEE_LOVELACE=2000000
PLATFORM_WALLET_MNEMONIC=
PLATFORM_WALLET_MNEMONIC_PREPROD="word1 word2 ... word24"
PLATFORM_WALLET_MNEMONIC_MAINNET="word1 word2 ... word24"

# ── On-chain Proofs ───────────────────────────────────────────────────────────
# Cardano tx metadata label used to anchor proof records on-chain
NEXT_PUBLIC_PROOF_LABEL=5757

# ── Realtime — Pusher ─────────────────────────────────────────────────────────
# Primary realtime push provider — get credentials at pusher.com
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=mt1

# ── Realtime — Ably ───────────────────────────────────────────────────────────
# Fallback realtime provider — set NEXT_PUBLIC_ABLY_ENABLED=true to activate
ABLY_API_KEY=
NEXT_PUBLIC_ABLY_ENABLED=false

# ── Storage — Cloudinary ──────────────────────────────────────────────────────
# Avatar and deliverable file uploads — get credentials at cloudinary.com
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
