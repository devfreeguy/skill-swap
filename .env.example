# DB and Auth
DATABASE_URL=<some_url>
JWT_SECRET=some_secret

# Network
NEXT_PUBLIC_BLOCKFROST_NETWORK=preprod
NEXT_PUBLIC_CARDANO_NETWORK=preprod

# App base URL — used to build the Twitter OAuth redirect/callback URL
NEXTAUTH_URL=http://localhost:3000

# Twitter / X OAuth2 app credentials (https://developer.x.com)
# Callback URL to register on X: ${NEXTAUTH_URL}/api/auth/twitter/callback
TWITTER_CLIENT_ID=get_from_x_developer
TWITTER_CLIENT_SECRET=get_from_x_developer

# On-chain proof tx submission/confirmation — providers tried in fallback order:
# Blockfrost → Koios (free, no key) → Maestro. Only Koios is required.
NEXT_PUBLIC_BLOCKFROST_API_KEY=
BLOCKFROST_API_KEY=get_from_blockfrost_api
MAESTRO_API_KEY=get_from_getmaestro_org

# Transaction metadata label for proof records (any unused integer)
NEXT_PUBLIC_PROOF_LABEL=5757

# Swap platform fee
# The initiator pays this fee when requesting a swap; it is refunded ONLY if the
# receiver declines. Leave NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS blank to disable
# fees entirely (e.g. local dev).
#
# Public: the receive/treasury address (base address addr1…/addr_test1…) the
# browser pays the fee to.
NEXT_PUBLIC_PLATFORM_WALLET_ADDRESS=addr_test1...
# Public: fee amount in lovelace (default 2_000_000 = 2 ADA). Keep it above the
# protocol min-UTxO (~1 ADA).
NEXT_PUBLIC_SWAP_FEE_LOVELACE=2000000
# Server-only secret: the treasury wallet's seed phrase, used to sign refunds.
# Fund this wallet so it can cover refunds + tx fees. BLOCKFROST_API_KEY above is
# REQUIRED when this is set (the refund tx is built/submitted via Blockfrost).
PLATFORM_WALLET_MNEMONIC="word1 word2 ... word24"

# Pusher Channels (https://pusher.com) - server + client
PUSHER_APP_ID=1111111
PUSHER_KEY=some_key
PUSHER_SECRET=some_secret
PUSHER_CLUSTER=some_cluster
NEXT_PUBLIC_PUSHER_KEY=some_key
NEXT_PUBLIC_PUSHER_CLUSTER=some_cluster

# Ably (https://ably.com) - fallback. Set NEXT_PUBLIC_ABLY_ENABLED=true to have
# the client also subscribe via Ably. Leave blank to run Pusher-only.
ABLY_API_KEY=get_from_ably
NEXT_PUBLIC_ABLY_ENABLED=false

# Storage
CLOUDINARY_CLOUD_NAME=some_name
CLOUDINARY_API_KEY=some_key
CLOUDINARY_API_SECRET=some_secret